// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum CarType {
  SEDAN
  SUV
  SPORT
  COUPE
  HATCHBACK
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  rentals   Rental[]
  favorites Favorite[]
  addedCars Car[]      @relation("AdminCars")
}

model Car {
  id             String  @id @default(cuid())
  name           String
  type           CarType
  fuelCapacity   Float
  transmission   String
  passengerLimit Int
  imageUrl       String

  location       String  @default("Tbilisi")

  pricePerDay    Float
  discountPrice  Float?
  hasDiscount    Boolean @default(false)

  isAvailable    Boolean @default(true)

  userId String?
  admin  User?   @relation("AdminCars", fields: [userId], references: [id])

  rentals     Rental[]
  favoritedBy Favorite[]
}

model Rental {
  id     String @id @default(cuid())
  userId String
  carId  String

  pickupLocation  String
  pickupDate      DateTime
  pickupTime      String

  dropoffLocation String
  dropoffDate     DateTime
  dropoffTime     String

  totalPrice Float
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  car  Car  @relation(fields: [carId], references: [id])
}

model Favorite {
  id     String @id @default(cuid())
  userId String
  carId  String

  user User @relation(fields: [userId], references: [id])
  car  Car  @relation(fields: [carId], references: [id])

  @@unique([userId, carId])
}
